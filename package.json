{
  "name": "notras",
  "version": "0.0.0",
  "private": true,
  "description": "Just write, otra vez.",
  "type": "module",
  "scripts": {
    "build": "next build",
    "clean": "rm -rf .next",
    "coverage": "vitest run --coverage",
    "db:push": "drizzle-kit push",
