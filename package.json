    "clsx": "2.1.1",
    "drizzle-orm": "0.43.1",
    "drizzle-zod": "0.7.1",
    "next": "15.4.0-canary.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sharp": "0.34.1",
    "tailwind-merge": "2.5.4",
    "zod": "3.24.3"
  },
  "devDependencies": {
    "@iconify-json/lucide": "1.2.39",
    "@iconify-json/simple-icons": "1.2.11",
    "@iconify/tailwind": "1.2.0",
