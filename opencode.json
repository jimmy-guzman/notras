{
  "$schema": "https://opencode.ai/config.json",
  "formatter": {
    "prettier": {
      "disabled": true
    },
    "oxfmt": {
      "command": ["npx", "oxfmt", "--write", "$FILE"],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx",
        ".css",
        ".md",
        ".json",
        ".yaml",
        ".yml",
        ".html"
      ]
    }
  },
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true
    },
    "eslint": {
      "type": "local",
      "command": ["npx", "@eslint/mcp@latest"],
      "enabled": true
    },
    "knip": {
      "type": "local",
      "command": ["npx", "@knip/mcp@latest"],
      "enabled": true
    },
    "next.js": {
      "type": "local",
      "command": ["npx", "next-devtools-mcp@latest"],
      "enabled": true
    }
  }
}
