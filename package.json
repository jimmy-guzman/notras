    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "knip": "SKIP_ENV_VALIDATION=1 knip",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint/",
    "lint:fix": "eslint . --fix --cache --cache-location node_modules/.cache/eslint/",
    "prepare": "is-ci || lefthook install",
    "start": "next start",
    "test": "vitest",
    "typecheck": "tsc"
  },
  "dependencies": {
