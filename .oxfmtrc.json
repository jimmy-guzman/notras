{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "jsxSingleQuote": false,
  "experimentalTailwindcss": {
    "stylesheet": "./src/app/globals.css"
  },
  "printWidth": 80,
  "quoteProps": "consistent",
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "experimentalSortPackageJson": {},
  "ignorePatterns": [
    "pnpm-lock.yaml",
    "CHANGELOG.md",
    "*.gen.*",
    ".next",
    "dist",
    "coverage",
    "node_modules"
  ]
}
