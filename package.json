{
  "name": "notras",
  "version": "0.0.0",
  "private": true,
  "description": "A simple space to capture your thoughts as they come.",
  "type": "module",
  "scripts": {
    "build": "next build",
    "clean": "rm -rf .next",
    "coverage": "vitest run --coverage",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev": "next dev --turbopack",
    "format": "prettier --check --cache .",
    "format:fix": "prettier --write --cache .",
    "knip": "SKIP_ENV_VALIDATION=1 knip",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint/",
    "lint:fix": "eslint . --fix --cache --cache-location node_modules/.cache/eslint/",
    "prepare": "is-ci || lefthook install",
    "start": "next start",
    "test": "vitest",
    "typecheck": "tsc"
  },
  "prettier": "@jimmy.codes/prettier-config",
  "dependencies": {
    "@hookform/resolvers": "5.0.1",
    "@libsql/client": "0.15.4",
    "@radix-ui/react-avatar": "1.1.9",
    "@radix-ui/react-dropdown-menu": "2.1.14",
    "@radix-ui/react-label": "2.1.6",
    "@radix-ui/react-select": "2.2.4",
    "@radix-ui/react-separator": "1.1.6",
    "@radix-ui/react-slot": "1.2.2",
    "@radix-ui/react-toggle": "1.1.8",
    "@radix-ui/react-toggle-group": "1.1.9",
    "@radix-ui/react-tooltip": "1.2.6",
    "@t3-oss/env-nextjs": "0.13.4",
    "better-auth": "1.2.7",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "drizzle-orm": "0.43.1",
    "framer-motion": "12.10.1",
    "lucide-react": "0.508.0",
    "nanoid": "5.1.5",
    "next": "15.4.0-canary.17",
    "next-themes": "0.4.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "7.56.3",
    "resend": "4.5.1",
    "sonner": "2.0.3",
    "tailwind-merge": "3.2.0",
    "tiny-invariant": "1.3.3",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@iconify-json/lucide": "1.2.41",
    "@iconify/tailwind4": "1.0.6",
    "@jimmy.codes/eslint-config": "5.12.0",
    "@jimmy.codes/prettier-config": "1.5.0",
    "@tailwindcss/postcss": "4.1.5",
    "@tailwindcss/typography": "0.5.16",
    "@testing-library/dom": "10.4.0",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/node": "22.15.15",
    "@types/react": "19.1.3",
    "@types/react-dom": "19.1.3",
    "@vitejs/plugin-react": "4.4.1",
    "@vitest/coverage-v8": "3.1.3",
    "daisyui": "5.0.35",
    "drizzle-kit": "0.31.1",
    "eslint": "9.26.0",
    "gitzy": "5.8.1",
    "happy-dom": "17.4.6",
    "is-ci": "4.1.0",
    "jiti": "2.4.2",
    "knip": "5.55.0",
    "lefthook": "1.11.12",
    "postcss": "8.5.3",
    "prettier": "3.5.3",
    "tailwindcss": "4.1.5",
    "tw-animate-css": "1.2.9",
    "typescript": "5.8.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.1.3"
  },
  "packageManager": "pnpm@10.10.0"
}
