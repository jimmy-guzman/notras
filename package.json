    "@vitest/coverage-v8": "3.1.2",
    "autoprefixer": "10.4.21",
    "daisyui": "4.12.14",
    "drizzle-kit": "0.31.0",
    "eslint": "9.25.1",
    "gitzy": "5.8.1",
